# Copy to `.env` and fill in. Never commit `.env`.

# ── Netlify DB (Neon Postgres) ──────────────────────────────
# Auto-injected by `netlify db init` in deploys. For local dev/migrations,
# paste your Neon connection string here.
NETLIFY_DATABASE_URL=

# Flip the client from the demo (localStorage) store to the live backend
# (Netlify Functions + Neon). Set to "true" once the DB is provisioned + migrated.
VITE_USE_API=

# ── Neon Auth (Stack Auth) ──────────────────────────────────
# From your Neon project's "Auth" tab after enabling Neon Auth.
# VITE_* vars are exposed to the browser (safe — publishable only).
VITE_STACK_PROJECT_ID=
VITE_STACK_PUBLISHABLE_CLIENT_KEY=
# Server-only — used by Netlify Functions to verify sessions. NEVER expose.
STACK_SECRET_SERVER_KEY=

# ── Anthropic (Phase 3 — Netlify Functions only) ────────────
ANTHROPIC_API_KEY=
